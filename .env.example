# Netlify Functions Environment Variables

# Database Configuration (MySQL - Aiven)
# Option 1: Full connection string
DATABASE_URL=mysql://avnadmin:PASSWORD@room-booking-mysql-roombooking21.g.aivencloud.com:14255/defaultdb?sslMode=REQUIRED

# Option 2: Individual database parameters (alternative to DATABASE_URL)
DB_HOST=room-booking-mysql-roombooking21.g.aivencloud.com
DB_PORT=14255
DB_USER=avnadmin
DB_PASSWORD=your-password-here
DB_NAME=defaultdb

# Email Configuration (for sending notifications)
# Choose one: SMTP or Email API
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@roombooking.system

# Alternative: Use email API service (e.g., SendGrid, Mailgun, Resend)
# EMAIL_API_KEY=your-api-key
# EMAIL_API_URL=https://api.email-service.com/send

# Security
MAX_LOGIN_ATTEMPTS=10
LOGIN_LOCK_MINUTES=360

# Booking Rules
OPEN_TIME=08:30
CLOSE_TIME=17:00
REMINDER_MINUTES=15
