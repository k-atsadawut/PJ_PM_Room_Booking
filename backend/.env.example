PORT=3000
APP_ENV=development

# MySQL (ไม่ใช่ Neon/PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=room_booking_system
DB_USER=root
DB_PASS=
DB_SSL=true
DB_SSL_CA_PATH=./certs/aiven-ca.pem         

# Session
SESSION_SECRET=change-this-to-a-long-random-secret
SESSION_LIFETIME=21600000

# Login Security (FR-14)
MAX_LOGIN_ATTEMPTS=10
LOGIN_LOCK_MINUTES=360

# Mail (FR-09)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com
